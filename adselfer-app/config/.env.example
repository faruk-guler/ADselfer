# AD Server Settings
AD_URL=ldaps://ad-server-ip:636
AD_BASE_DN=OU=Users,DC=company,DC=com
AD_DOMAIN=company.com

# Service Account for ADselfer
AD_SERVICE_ACCOUNT_DN=CN=svc_adselfer,OU=Services,DC=company,DC=com
AD_SERVICE_ACCOUNT_PW=StrongPassword123

# SMTP Settings for Email OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sspr@company.com
SMTP_PASS=app-specific-password
SMTP_FROM=ADselfer SSPR <sspr@company.com>

# App Settings
PORT=3000
SECRET_SALT=your-random-salt-string
OTP_EXPIRY_MINS=5
PWD_MIN_LENGTH=12

# Admin Settings
ADMIN_USER=admin
ADMIN_PASS=ChangeMe123!
